# ── Database ──────────────────────────────────────────────
POSTGRES_USER=waypoint
POSTGRES_PASSWORD=change_me
POSTGRES_DB=waypoint
DATABASE_URL=postgresql://waypoint:change_me@localhost:5432/waypoint?schema=public

# ── Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# ── Cross-origin ──────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Email (password reset / verification) ────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Waypoint <no-reply@waypoint.app>"

# ── File storage ──────────────────────────────────────────
# Local disk for dev; swap for S3-compatible provider in production
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
